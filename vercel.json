{
  "version": 2,
  "builds": [
    { "src": "api/ai.js",    "use": "@vercel/node" },
    { "src": "api/posts.js", "use": "@vercel/node" },
    { "src": "index.html",   "use": "@vercel/static" },
    { "src": "script.js",    "use": "@vercel/static" }
  ],
  "routes": [
    { "src": "/api/ai",    "dest": "/api/ai.js" },
    { "src": "/api/posts", "dest": "/api/posts.js" },
    { "src": "/(.*)",      "dest": "/$1" }
  ]
}
